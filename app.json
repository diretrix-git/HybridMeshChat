{
  "expo": {
    "name": "HybridMeshChat",
    "slug": "hybridmeshchat",
    "owner": "diretrix",
    "version": "1.0.0",
    "sdkVersion": "50.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hybridmeshchat.app"
    },
    "android": {
      "package": "com.hybridmeshchat.app",
      "permissions": [
        "INTERNET",
        "CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow HybridMeshChat to access your camera for QR code scanning."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1d3e61f4-0814-47f1-9800-ee8d551cbe5d"
      }
    }
  }
}
